# App
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true

# LLM Providers
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
OPENAI_MODEL=gpt-4-turbo-preview

# Auth
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default seeded users
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-admin-password
DEFAULT_USER_USERNAME=irving
DEFAULT_USER_PASSWORD=change-user-password

# Runtime limits
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1500
LLM_REQUEST_TIMEOUT=12
DEEPSEEK_FLASH_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.028
DEEPSEEK_FLASH_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=0.14
DEEPSEEK_FLASH_OUTPUT_PRICE_USD_PER_MILLION=0.28
DEEPSEEK_PRO_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.145
DEEPSEEK_PRO_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=1.74
DEEPSEEK_PRO_OUTPUT_PRICE_USD_PER_MILLION=3.48
CONVERSATION_HISTORY_LIMIT=20
OPENCODE_TIMEOUT=30
