# App
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true
# Comma-separated origins. Keep "*" only for trusted local deployments.
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_REASONER_MODEL=deepseek-reasoner
# Uses api.deepseek.com/beta for strict function calling.
# Override for standard API: DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_BASE_URL=https://api.deepseek.com/beta
DEEPSEEK_THINKING_ENABLED=true
DEEPSEEK_REASONING_EFFORT=high
# reasoning_effort options: high (default), max

# Auth
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default seeded users (change after first login)
DEFAULT_ADMIN_USERNAME=admin
# The installer prompts for this value. Change it for any non-local environment.
DEFAULT_ADMIN_PASSWORD=admin
# Uncomment to seed an additional non-admin user:
# DEFAULT_USER_USERNAME=dev
# DEFAULT_USER_PASSWORD=dev

# Dev workspace paths (auto-detected from $HOME if not set)
# DEV_WORKSPACE_ROOT=/home/dev
# DEV_REPOS_ROOT=/home/dev/repos
# DEV_PROJECTS_JSON={"my-project":{"path":"/path/to/project","type":"python","priority":"high"}}

# Runtime state paths (installer writes these to the per-user runtime config)
# MEMORY_DB_PATH=/home/dev/.local/share/devsynapse-ai/data/devsynapse_memory.db
# MONITORING_DB_PATH=/home/dev/.local/share/devsynapse-ai/data/devsynapse_monitoring.db
# LOG_FILE=/home/dev/.local/state/devsynapse-ai/logs/devsynapse.log

# Runtime limits
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1500
LLM_REQUEST_TIMEOUT=12
LLM_DAILY_BUDGET_USD=1.0
LLM_MONTHLY_BUDGET_USD=20.0
LLM_BUDGET_WARNING_THRESHOLD_PCT=80
LLM_BUDGET_CRITICAL_THRESHOLD_PCT=100
LLM_MODEL_ROUTING_ENABLED=true
LLM_AUTO_ECONOMY_ENABLED=true
LLM_CACHE_HIT_WARNING_THRESHOLD_PCT=70
DEEPSEEK_FLASH_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.0028
DEEPSEEK_FLASH_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=0.14
DEEPSEEK_FLASH_OUTPUT_PRICE_USD_PER_MILLION=0.28
DEEPSEEK_PRO_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.003625
DEEPSEEK_PRO_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=0.435
DEEPSEEK_PRO_OUTPUT_PRICE_USD_PER_MILLION=0.87
CONVERSATION_HISTORY_LIMIT=20
OPENCODE_TIMEOUT=30
