# App
API_HOST=127.0.0.1
API_PORT=8000
API_DEBUG=true

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Auth
JWT_SECRET_KEY=change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Default seeded users
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=change-admin-password
DEFAULT_USER_USERNAME=irving
DEFAULT_USER_PASSWORD=change-user-password

# Dev workspace paths (auto-detected from $HOME if not set)
# DEV_WORKSPACE_ROOT=/home/irving
# DEV_REPOS_ROOT=/home/irving/repos
# DEV_PROJECTS_JSON={"my-project":{"path":"/path/to/project","type":"python","priority":"high"}}

# Runtime limits
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1500
LLM_REQUEST_TIMEOUT=12
LLM_DAILY_BUDGET_USD=1.0
LLM_MONTHLY_BUDGET_USD=20.0
LLM_BUDGET_WARNING_THRESHOLD_PCT=80
LLM_BUDGET_CRITICAL_THRESHOLD_PCT=100
DEEPSEEK_FLASH_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.028
DEEPSEEK_FLASH_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=0.14
DEEPSEEK_FLASH_OUTPUT_PRICE_USD_PER_MILLION=0.28
DEEPSEEK_PRO_INPUT_CACHE_HIT_PRICE_USD_PER_MILLION=0.145
DEEPSEEK_PRO_INPUT_CACHE_MISS_PRICE_USD_PER_MILLION=1.74
DEEPSEEK_PRO_OUTPUT_PRICE_USD_PER_MILLION=3.48
CONVERSATION_HISTORY_LIMIT=20
OPENCODE_TIMEOUT=30
