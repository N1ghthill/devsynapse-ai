{
  "name": "devsynapse-ai",
  "private": true,
  "version": "0.6.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "capture:docs-screenshots": "node scripts/capture-doc-screenshots.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:updates": "tauri build --config src-tauri/tauri.updater.conf.json",
    "tauri:build:appimage": "tauri build -- --bundles appimage",
    "backend:build": "bash ../scripts/build-backend.sh",
    "desktop:dev": "npm run backend:build && npm run tauri:dev",
    "desktop:build": "npm run backend:build && npm run tauri:build",
    "icons:tauri": "tauri icon ../assets/Favcon.png"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "axios": "^1.15.2",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "playwright": "^1.59.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10"
  }
}
